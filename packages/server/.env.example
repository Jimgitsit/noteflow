# NoteFlow Backend — Environment Variables
# Copy this file to .env and fill in the values.

# Runtime environment: development | test | production
NODE_ENV=development

# Port for the Express server
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/noteflow

# JWT signing secret (minimum 32 characters — use a strong random value in production)
JWT_SECRET=replace-with-a-strong-random-secret-key

# JWT expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d

# Secret for signed cookies
COOKIE_SECRET=replace-with-another-strong-random-secret

# Allowed frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Rate limiting — auth endpoints
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
